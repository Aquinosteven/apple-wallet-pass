{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:prerender",
    "build:prerender": "vite build --ssr src/prerender.tsx --outDir dist-server && node scripts/prerender-static.mjs",
    "lint": "eslint .",
    "test": "node --test tests/*.test.js",
    "qa:wallet:env": "node scripts/check-wallet-test-env.js",
    "qa:wallet:install-browsers": "playwright install chromium webkit",
    "qa:wallet:claim-sim": "node scripts/mobile-wallet-claim-sim.js",
    "qa:ui": "bash ./scripts/run-ui-qa-agent.sh",
    "gsc:auth": "node scripts/run-gsc-command.js auth",
    "gsc:sites": "node scripts/run-gsc-command.js sites",
    "gsc:top-queries": "node scripts/run-gsc-command.js top-queries",
    "gsc:target-keywords": "node scripts/run-gsc-command.js target-keywords",
    "check:prod-schema": "node scripts/check-prod-schema.js",
    "check:migration-versions": "node scripts/check-migration-versions.js",
    "check:migration-rls": "node scripts/check-migration-rls.js",
    "test:thread-c:smoke": "node scripts/thread-c-smoke.js",
    "test:thread-c:load": "node scripts/thread-c-load.js",
    "integration:pack": "./scripts/integration-command-pack.sh",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@vercel/analytics": "^2.0.1",
    "google-auth-library": "^9.15.1",
    "lucide-react": "^0.344.0",
    "passkit-generator": "^3.5.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "baseline-browser-mapping": "^2.10.9",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "playwright": "^1.59.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^8.0.9"
  }
}
