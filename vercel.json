{
  "functions": {
    "api/pass.js": {
      "includeFiles": "event-ticket.pass/**"
    },
    "api/ghl-pass.js": {
      "includeFiles": "event-ticket.pass/**"
    },
    "api/online-event.js": {
      "includeFiles": "event-ticket.pass/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/selftest-issue-claim",
      "destination": "/api/health?mode=selftest-issue-claim"
    },
    {
      "source": "/api/passkit-test",
      "destination": "/api/health?mode=pass"
    },
    {
      "source": "/api/client-pass",
      "destination": "/api/pass"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/functions/api/(.*)",
      "destination": "/functions/api/$1"
    },
    {
      "source": "/((?!api/|functions/api/|showfi-claim\\.js$).*)",
      "destination": "/"
    }
  ]
}
